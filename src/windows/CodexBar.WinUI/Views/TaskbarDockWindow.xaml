<Window
    x:Class="CodexBar.WinUI.Views.TaskbarDockWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CodexBar.WinUI.ViewModels">

    <Grid Padding="8">
        <ItemsRepeater x:Name="TilesRepeater" ItemsSource="{x:Bind ViewModel.Tiles, Mode=OneWay}">
            <ItemsRepeater.Layout>
                <StackLayout Orientation="Horizontal" Spacing="6" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="vm:TaskbarDockTileViewModel">
                    <Border Padding="8,6" CornerRadius="8"
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            MinWidth="88">
                        <Grid RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Grid.Row="0"
                                Text="{x:Bind ProviderName}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                FontWeight="SemiBold"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind PercentText}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Opacity="0.7"
                                TextTrimming="CharacterEllipsis" />
                            <ProgressBar
                                Grid.Row="2"
                                Maximum="100"
                                Value="{x:Bind ProgressPercent}"
                                Margin="0,4,0,0"
                                Height="3"
                                Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>
    </Grid>
</Window>
