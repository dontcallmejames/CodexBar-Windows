<Window
    x:Class="CodexBar.WinUI.Views.PopoverWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:CodexBar.WinUI.ViewModels"
    xmlns:core="using:CodexBar.Core.Models">

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Provider tabs along the top -->
        <controls:NavigationView
            Grid.Row="0"
            x:Name="ProviderNav"
            PaneDisplayMode="Top"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionChanged="ProviderNav_SelectionChanged">
            <controls:NavigationView.MenuItems>
                <controls:NavigationViewItem Content="Codex" Tag="Codex" />
                <controls:NavigationViewItem Content="Claude" Tag="Claude" />
                <controls:NavigationViewItem Content="Cursor" Tag="Cursor" />
                <controls:NavigationViewItem Content="Gemini" Tag="Gemini" />
            </controls:NavigationView.MenuItems>
        </controls:NavigationView>

        <!-- Active-provider content -->
        <ScrollViewer Grid.Row="1" VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="8">
                <TextBlock
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="{x:Bind ViewModel.ActiveSnapshot.DisplayName, Mode=OneWay, FallbackValue=''}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Opacity="0.8"
                        Text="{x:Bind ViewModel.UpdatedText, Mode=OneWay}" />
                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Opacity="0.8"
                        Text="{x:Bind ViewModel.PlanText, Mode=OneWay}" />
                </Grid>

                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Metrics, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="14" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:PopoverMetricViewModel">
                            <StackPanel Spacing="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        Text="{x:Bind Title}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Opacity="0.75"
                                        Text="{x:Bind PercentText}" />
                                </Grid>
                                <ProgressBar
                                    Maximum="100"
                                    Value="{x:Bind PercentValue}"
                                    Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                                <TextBlock
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Opacity="0.65"
                                    Text="{x:Bind ResetText}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer with live indicator -->
        <TextBlock
            Grid.Row="2"
            Style="{StaticResource CaptionTextBlockStyle}"
            Opacity="0.6"
            Text="{x:Bind ViewModel.LiveIndicatorText, Mode=OneWay}" />
    </Grid>
</Window>
