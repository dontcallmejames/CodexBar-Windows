<Window
    x:Class="CodexBar.WinUI.Views.PopoverWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:CodexBar.WinUI.ViewModels"
    xmlns:core="using:CodexBar.Core.Models">

    <Grid Padding="16" RowSpacing="12">
        <!-- WinUI 3's Window class has no Resources property — put styles on the root content element instead. -->
        <Grid.Resources>
            <Style x:Key="FooterIconButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="6" />
                <Setter Property="MinWidth" Value="32" />
                <Setter Property="MinHeight" Value="32" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Provider tabs along the top. MenuItems is populated in code-behind from
             the current snapshot set so disabled providers never render. -->
        <controls:NavigationView
            Grid.Row="0"
            x:Name="ProviderNav"
            PaneDisplayMode="Top"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionChanged="ProviderNav_SelectionChanged">
        </controls:NavigationView>

        <!-- Close (X) button floats over the right edge of the tabs row.
             Single source of dismissal that also matches click-outside-to-dismiss. -->
        <Button Grid.Row="0"
                x:Name="CloseButton"
                Style="{StaticResource FooterIconButton}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,4,4,0"
                Canvas.ZIndex="10"
                AutomationProperties.AutomationId="PopoverCloseButton"
                AutomationProperties.Name="Close"
                ToolTipService.ToolTip="Close"
                Click="CloseButton_Click">
            <FontIcon Glyph="&#xE8BB;" FontSize="12" />
        </Button>

        <!-- Active-provider content -->
        <ScrollViewer Grid.Row="1" VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="8">
                <TextBlock
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="{x:Bind ViewModel.ActiveSnapshot.DisplayName, Mode=OneWay, FallbackValue=''}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Opacity="0.8"
                        Text="{x:Bind ViewModel.UpdatedText, Mode=OneWay}" />
                    <TextBlock
                        Grid.Column="1"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Opacity="0.8"
                        Text="{x:Bind ViewModel.PlanText, Mode=OneWay}" />
                </Grid>

                <controls:InfoBar Severity="Warning" IsClosable="False"
                                  IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                                  Message="{x:Bind ViewModel.ErrorText, Mode=OneWay}"
                                  AutomationProperties.AutomationId="PopoverAuthInfoBar">
                    <controls:InfoBar.ActionButton>
                        <Button Content="Reconnect" Command="{x:Bind ViewModel.ReconnectCommand}"
                                AutomationProperties.AutomationId="PopoverReconnectButton" />
                    </controls:InfoBar.ActionButton>
                </controls:InfoBar>

                <ItemsRepeater ItemsSource="{x:Bind ViewModel.Metrics, Mode=OneWay}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="14" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="vm:PopoverMetricViewModel">
                            <StackPanel Spacing="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Style="{StaticResource BodyStrongTextBlockStyle}"
                                        Text="{x:Bind Title}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Style="{StaticResource BodyTextBlockStyle}"
                                        Opacity="0.75"
                                        Text="{x:Bind PercentText}" />
                                </Grid>
                                <ProgressBar
                                    Maximum="100"
                                    Value="{x:Bind PercentValue}"
                                    Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                                <TextBlock
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Opacity="0.65"
                                    Text="{x:Bind ResetText}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>

                <!-- Local Claude Code token usage (ccusage-style). Visible only on the Claude tab
                     when at least one assistant message with usage exists for today. -->
                <TextBlock
                    x:Name="LocalTokensCaption"
                    AutomationProperties.AutomationId="PopoverLocalTokensCaption"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Opacity="0.75"
                    Visibility="{x:Bind ViewModel.LocalTokensVisibility, Mode=OneWay}"
                    Text="{x:Bind ViewModel.LocalTokensText, Mode=OneWay}" />
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom row: footer commands + live indicator -->
        <Grid Grid.Row="2" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.6"
                       Text="{x:Bind ViewModel.LiveIndicatorText, Mode=OneWay}" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                <Button Style="{StaticResource FooterIconButton}"
                        AutomationProperties.AutomationId="PopoverAddAccountButton"
                        AutomationProperties.Name="Add Account"
                        Command="{x:Bind ViewModel.AddAccountCommand}"
                        ToolTipService.ToolTip="Add Account">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                </Button>
                <Button Style="{StaticResource FooterIconButton}"
                        AutomationProperties.AutomationId="PopoverDashboardButton"
                        AutomationProperties.Name="Open Dashboard"
                        Command="{x:Bind ViewModel.DashboardCommand}"
                        ToolTipService.ToolTip="Open Dashboard">
                    <FontIcon Glyph="&#xE9D2;" FontSize="14" />
                </Button>
                <Button Style="{StaticResource FooterIconButton}"
                        AutomationProperties.AutomationId="PopoverStatusButton"
                        AutomationProperties.Name="Status Page"
                        Command="{x:Bind ViewModel.StatusPageCommand}"
                        ToolTipService.ToolTip="Status Page">
                    <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                </Button>
                <Button Style="{StaticResource FooterIconButton}"
                        AutomationProperties.AutomationId="PopoverSettingsButton"
                        AutomationProperties.Name="Settings"
                        Command="{x:Bind ViewModel.SettingsCommand}"
                        ToolTipService.ToolTip="Settings">
                    <FontIcon Glyph="&#xE713;" FontSize="14" />
                </Button>
                <Button Style="{StaticResource FooterIconButton}"
                        AutomationProperties.AutomationId="PopoverAboutButton"
                        AutomationProperties.Name="About"
                        Command="{x:Bind ViewModel.AboutCommand}"
                        ToolTipService.ToolTip="About">
                    <FontIcon Glyph="&#xE946;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
