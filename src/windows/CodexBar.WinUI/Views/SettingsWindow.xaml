<Window
    x:Class="CodexBar.WinUI.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctk="using:CommunityToolkit.WinUI.Controls"
    Title="CodexBar Settings">
    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource TitleTextBlockStyle}" Text="Settings" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">

                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Providers" />
                <ctk:SettingsCard Header="Codex">
                    <ToggleSwitch AutomationProperties.AutomationId="SettingsCodexEnabledToggle"
                                  IsOn="{x:Bind ViewModel.CodexEnabled, Mode=TwoWay}" />
                </ctk:SettingsCard>
                <ctk:SettingsCard Header="Claude">
                    <ToggleSwitch AutomationProperties.AutomationId="SettingsClaudeEnabledToggle"
                                  IsOn="{x:Bind ViewModel.ClaudeEnabled, Mode=TwoWay}" />
                </ctk:SettingsCard>
                <ctk:SettingsCard Header="Cursor">
                    <ToggleSwitch AutomationProperties.AutomationId="SettingsCursorEnabledToggle"
                                  IsOn="{x:Bind ViewModel.CursorEnabled, Mode=TwoWay}" />
                </ctk:SettingsCard>
                <ctk:SettingsCard Header="Gemini">
                    <ToggleSwitch AutomationProperties.AutomationId="SettingsGeminiEnabledToggle"
                                  IsOn="{x:Bind ViewModel.GeminiEnabled, Mode=TwoWay}" />
                </ctk:SettingsCard>
                <ctk:SettingsCard Header="Copilot" Description="Requires `gh auth login` first.">
                    <ToggleSwitch AutomationProperties.AutomationId="SettingsCopilotEnabledToggle"
                                  IsOn="{x:Bind ViewModel.CopilotEnabled, Mode=TwoWay}" />
                </ctk:SettingsCard>
                <ctk:SettingsCard Header="Antigravity" Description="Reads Claude + Gemini quota from the local Antigravity language server. Antigravity must be running.">
                    <ToggleSwitch AutomationProperties.AutomationId="SettingsAntigravityEnabledToggle"
                                  IsOn="{x:Bind ViewModel.AntigravityEnabled, Mode=TwoWay}" />
                </ctk:SettingsCard>

                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Refresh" Margin="0,12,0,0" />
                <ctk:SettingsCard Header="Refresh interval" Description="How often CodexBar queries each provider (in minutes).">
                    <NumberBox x:Name="RefreshMinutesNumberBox"
                               AutomationProperties.AutomationId="SettingsRefreshMinutesNumber"
                               Minimum="1" Maximum="1440"
                               Value="{x:Bind ViewModel.RefreshMinutes, Mode=TwoWay}"
                               Width="100" SpinButtonPlacementMode="Compact" />
                </ctk:SettingsCard>

                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Display" Margin="0,12,0,0" />
                <ctk:SettingsCard Header="Show taskbar dock" Description="Pin a compact overview near the taskbar.">
                    <ToggleSwitch AutomationProperties.AutomationId="SettingsDockOverviewToggle"
                                  IsOn="{x:Bind ViewModel.DockOverviewNearTaskbar, Mode=TwoWay}" />
                </ctk:SettingsCard>
                <ctk:SettingsCard Header="Show usage as used" Description="When off, shows remaining instead of used.">
                    <ToggleSwitch AutomationProperties.AutomationId="SettingsShowUsageAsUsedToggle"
                                  IsOn="{x:Bind ViewModel.ShowUsageAsUsed, Mode=TwoWay}" />
                </ctk:SettingsCard>

                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="General" Margin="0,12,0,0" />
                <ctk:SettingsCard Header="Global hotkey" Description="System-wide shortcut to toggle the CodexBar popover.">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox AutomationProperties.AutomationId="SettingsGlobalHotkeyText"
                                 Text="{x:Bind ViewModel.GlobalHotkey, Mode=OneWay}"
                                 IsReadOnly="True" Width="160" VerticalAlignment="Center" />
                        <Button AutomationProperties.AutomationId="SettingsRebindHotkeyButton"
                                Content="Rebind..." Click="RebindHotkey_Click" />
                    </StackPanel>
                </ctk:SettingsCard>
                <ctk:SettingsCard Header="Enable global hotkey" Description="Register the shortcut system-wide.">
                    <ToggleSwitch AutomationProperties.AutomationId="SettingsEnableGlobalHotkeyToggle"
                                  IsOn="{x:Bind ViewModel.EnableGlobalHotkey, Mode=TwoWay}" />
                </ctk:SettingsCard>
                <TeachingTip x:Name="HotkeyConflictTip"
                             Title="Hotkey unavailable"
                             Subtitle="This combination is in use by another app — choose a different one."
                             IsLightDismissEnabled="True" />

                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="System" Margin="0,12,0,0" />
                <ctk:SettingsCard Header="Launch at startup">
                    <ToggleSwitch AutomationProperties.AutomationId="SettingsLaunchAtStartupToggle"
                                  IsOn="{x:Bind ViewModel.LaunchAtStartup, Mode=TwoWay}" />
                </ctk:SettingsCard>
                <ctk:SettingsCard Header="Check for updates automatically" Description="Check GitHub releases every 24 hours.">
                    <ToggleSwitch AutomationProperties.AutomationId="SettingsCheckForUpdatesToggle"
                                  IsOn="{x:Bind ViewModel.CheckForUpdatesAutomatically, Mode=TwoWay}" />
                </ctk:SettingsCard>
                <ctk:SettingsCard Header="Install update"
                                  Description="{x:Bind ViewModel.InstallStatusText, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <ProgressBar AutomationProperties.AutomationId="SettingsInstallUpdateProgress"
                                     Width="120" Minimum="0" Maximum="100"
                                     Value="{x:Bind ViewModel.DownloadProgress, Mode=OneWay}"
                                     Visibility="{x:Bind ViewModel.ProgressVisibility, Mode=OneWay}" />
                        <Button AutomationProperties.AutomationId="SettingsCheckNowButton"
                                Content="Check now"
                                Command="{x:Bind ViewModel.CheckNowCommand}" />
                        <Button AutomationProperties.AutomationId="SettingsInstallUpdateButton"
                                Content="Install now"
                                Command="{x:Bind ViewModel.InstallUpdateCommand}"
                                IsEnabled="{x:Bind ViewModel.CanInstallUpdate, Mode=OneWay}" />
                    </StackPanel>
                </ctk:SettingsCard>

                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Advanced credentials" Margin="0,12,0,0" />
                <ctk:SettingsCard Header="Cursor manual cookie" Description="Cookie: header from a signed-in Cursor browser request.">
                    <PasswordBox AutomationProperties.AutomationId="SettingsCursorCookieText"
                                 Password="{x:Bind ViewModel.CursorManualCookieHeader, Mode=TwoWay}"
                                 PasswordRevealMode="Peek"
                                 Width="320" />
                </ctk:SettingsCard>
                <ctk:SettingsCard Header="Claude manual cookie" Description="Fallback when OAuth credentials are not available.">
                    <PasswordBox AutomationProperties.AutomationId="SettingsClaudeCookieText"
                                 Password="{x:Bind ViewModel.ClaudeManualCookieHeader, Mode=TwoWay}"
                                 PasswordRevealMode="Peek"
                                 Width="320" />
                </ctk:SettingsCard>

                <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Support" Margin="0,12,0,0" />
                <ctk:SettingsCard Header="Report a bug" Description="Copies a redacted diagnostic summary to your clipboard and opens the GitHub issue form.">
                    <Button AutomationProperties.AutomationId="SettingsReportBugButton"
                            Content="Report a Bug..." Command="{x:Bind ViewModel.OpenBugReportCommand}" />
                </ctk:SettingsCard>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button AutomationProperties.AutomationId="SettingsCancelButton"
                    Content="Cancel" Click="Cancel_Click" />
            <Button AutomationProperties.AutomationId="SettingsSaveButton"
                    Content="Save" Style="{StaticResource AccentButtonStyle}" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
