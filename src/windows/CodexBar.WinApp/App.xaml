<Application x:Class="CodexBar.WinApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
  <Application.Resources>
    <SolidColorBrush x:Key="CodexBarPanelBrush" Color="#EEE8FF" />
    <SolidColorBrush x:Key="CodexBarAccentBrush" Color="#2F7BF6" />
    <SolidColorBrush x:Key="CodexBarTextBrush" Color="#1F2937" />
    <SolidColorBrush x:Key="CodexBarMutedTextBrush" Color="#667085" />
  </Application.Resources>
</Application>
