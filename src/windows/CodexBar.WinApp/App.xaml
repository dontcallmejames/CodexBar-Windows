<Application x:Class="CodexBar.WinApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
  <Application.Resources>
    <SolidColorBrush x:Key="CodexBarPanelBrush" Color="#EAFFFFFF" />
    <SolidColorBrush x:Key="CodexBarAccentBrush" Color="#2F7BF6" />
    <SolidColorBrush x:Key="CodexBarTextBrush" Color="#20202A" />
    <SolidColorBrush x:Key="CodexBarMutedTextBrush" Color="#6B6678" />
  </Application.Resources>
</Application>
