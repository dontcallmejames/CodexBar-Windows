<Window x:Class="CodexBar.WinApp.Views.PopoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CodexBar.WinApp.Views"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Width="430"
        SizeToContent="Height"
        Background="Transparent">
  <Border CornerRadius="14"
          Background="{StaticResource CodexBarPanelBrush}"
          BorderBrush="#33000000"
          BorderThickness="1"
          Padding="18">
    <StackPanel>
      <ItemsControl ItemsSource="{Binding Tabs}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Rows="1" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Button Margin="3"
                    Padding="8"
                    BorderThickness="0"
                    Cursor="Hand"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Background="{Binding IsActive, Converter={x:Static views:BooleanToBrushConverter.Instance}}"
                    Command="{Binding DataContext.SelectProviderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding Provider}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}"
                          CornerRadius="8"
                          Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                  </Border>
                </ControlTemplate>
              </Button.Template>
              <StackPanel>
                <TextBlock Text="{Binding Title}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding PercentText}"
                           FontSize="11"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <TextBlock Text="{Binding ActiveSnapshot.DisplayName}"
                 FontSize="24"
                 FontWeight="Bold"
                 Foreground="{StaticResource CodexBarTextBrush}"
                 Margin="0,18,0,4" />
      <DockPanel Margin="0,0,0,12">
        <TextBlock Text="{Binding ActiveSnapshot.UpdatedAt, StringFormat=Updated {0:t}}"
                   Foreground="{StaticResource CodexBarMutedTextBrush}" />
        <TextBlock Text="{Binding ActiveSnapshot.Plan}"
                   DockPanel.Dock="Right"
                   HorizontalAlignment="Right"
                   Foreground="{StaticResource CodexBarMutedTextBrush}" />
      </DockPanel>

      <ItemsControl ItemsSource="{Binding ActiveSnapshot.Windows}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel Margin="0,10,0,8">
              <TextBlock Text="{Binding Title}"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource CodexBarTextBrush}" />
              <ProgressBar Value="{Binding UsedPercent}"
                           Maximum="100"
                           Height="8"
                           Margin="0,8,0,6" />
              <DockPanel>
                <TextBlock Text="{Binding UsedPercent, StringFormat={}{0:0}% used}"
                           Foreground="{StaticResource CodexBarTextBrush}" />
                <TextBlock Text="{Binding ResetsAt, StringFormat=Resets {0:t}}"
                           DockPanel.Dock="Right"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource CodexBarMutedTextBrush}" />
              </DockPanel>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Border BorderBrush="#22000000"
              BorderThickness="0,1,0,0"
              Margin="0,14,0,0"
              Padding="0,12,0,0">
        <StackPanel>
          <Button Content="Usage Dashboard"
                  Command="{Binding UsageDashboardCommand}"
                  HorizontalContentAlignment="Left"
                  Margin="0,2" />
          <Button Content="Settings..."
                  Command="{Binding SettingsCommand}"
                  HorizontalContentAlignment="Left"
                  Margin="0,2" />
          <Button Content="About CodexBar"
                  Command="{Binding AboutCommand}"
                  HorizontalContentAlignment="Left"
                  Margin="0,2" />
          <Button Content="Quit"
                  Command="{Binding QuitCommand}"
                  HorizontalContentAlignment="Left"
                  Margin="0,2" />
        </StackPanel>
      </Border>
    </StackPanel>
  </Border>
</Window>
