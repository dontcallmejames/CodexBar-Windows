<Window x:Class="CodexBar.WinApp.Views.PopoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CodexBar.WinApp.Views"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Width="372"
        SizeToContent="Height"
        Background="Transparent"
        FontFamily="Segoe UI">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <Style x:Key="ThinProgressBar" TargetType="ProgressBar">
      <Setter Property="Height" Value="6" />
      <Setter Property="Background" Value="#17000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ProgressBar">
            <Grid x:Name="PART_Track">
              <Border Background="{TemplateBinding Background}"
                      CornerRadius="3" />
              <Decorator x:Name="PART_Indicator"
                         HorizontalAlignment="Left">
                <Border Background="{TemplateBinding Foreground}"
                        CornerRadius="3" />
              </Decorator>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="MenuActionButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0,3" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Foreground" Value="{StaticResource CodexBarTextBrush}" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#14000000" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Border CornerRadius="16"
          Background="{StaticResource CodexBarPanelBrush}"
          BorderBrush="#99FFFFFF"
          BorderThickness="1"
          SnapsToDevicePixels="True">
    <Border.Effect>
      <DropShadowEffect BlurRadius="22"
                        ShadowDepth="6"
                        Opacity="0.18"
                        Color="#000000" />
    </Border.Effect>

    <StackPanel Margin="14,8,14,14">
      <ItemsControl ItemsSource="{Binding Tabs}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Rows="1" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Button Margin="2,0"
                    Padding="7,5,7,5"
                    BorderThickness="0"
                    Cursor="Hand"
                    Height="50"
                    Background="{Binding IsActive, Converter={x:Static views:BooleanToBrushConverter.Instance}}"
                    Foreground="{Binding IsActive, Converter={x:Static views:BooleanToForegroundBrushConverter.Instance}}"
                    Command="{Binding DataContext.SelectProviderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding Provider}">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}"
                          CornerRadius="8"
                          Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch" />
                  </Border>
                </ControlTemplate>
              </Button.Template>
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="17" />
                  <RowDefinition Height="16" />
                  <RowDefinition Height="6" />
                </Grid.RowDefinitions>
                <Viewbox Width="16"
                         Height="16"
                         HorizontalAlignment="Center">
                  <Path Data="{Binding IconGeometry}"
                        Stretch="Uniform"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Viewbox>
                <TextBlock Grid.Row="1"
                           Text="{Binding Title}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
                <ProgressBar Grid.Row="2"
                             Value="{Binding ProgressPercent}"
                             Maximum="100"
                             Height="3"
                             Margin="1,2,1,0"
                             Background="#26000000"
                             Foreground="{Binding ProgressColor}"
                             Style="{StaticResource ThinProgressBar}" />
              </Grid>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <TextBlock Text="{Binding ActiveSnapshot.DisplayName}"
                 FontSize="20"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource CodexBarTextBrush}"
                 Margin="12,16,12,1" />
      <DockPanel Margin="12,0,12,10"
                 LastChildFill="True">
        <TextBlock Text="{Binding UpdatedText}"
                   FontSize="13"
                   Foreground="{StaticResource CodexBarMutedTextBrush}" />
        <TextBlock Text="{Binding PlanText}"
                   DockPanel.Dock="Right"
                   FontSize="13"
                   HorizontalAlignment="Right"
                   Foreground="{StaticResource CodexBarMutedTextBrush}" />
      </DockPanel>

      <Border BorderBrush="#1F000000"
              BorderThickness="0,1,0,0"
              Margin="12,0,12,0" />

      <ItemsControl ItemsSource="{Binding Metrics}"
                    Margin="12,14,12,0">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel Margin="0,0,0,16">
              <TextBlock Text="{Binding Title}"
                         FontSize="17"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource CodexBarTextBrush}" />
              <ProgressBar Value="{Binding ProgressPercent}"
                           Maximum="100"
                           Height="5"
                           Margin="0,7,0,5"
                           Background="#17000000"
                           Foreground="{Binding ProgressColor}"
                           Style="{StaticResource ThinProgressBar}" />
              <DockPanel LastChildFill="True">
                <TextBlock Text="{Binding PercentText}"
                           FontSize="13"
                           Foreground="{StaticResource CodexBarTextBrush}" />
                <TextBlock Text="{Binding ResetText}"
                           DockPanel.Dock="Right"
                           FontSize="13"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource CodexBarMutedTextBrush}" />
              </DockPanel>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Border BorderBrush="#1F000000"
              BorderThickness="0,1,0,0"
              Margin="12,0,12,0"
              Visibility="{Binding HasCostSection, Converter={StaticResource BooleanToVisibilityConverter}}" />

      <StackPanel Margin="12,16,12,14"
                  Visibility="{Binding HasCostSection, Converter={StaticResource BooleanToVisibilityConverter}}">
        <TextBlock Text="Cost"
                   FontSize="17"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource CodexBarTextBrush}" />
        <TextBlock Text="{Binding CostTodayText}"
                   FontSize="13"
                   Margin="0,6,0,0"
                   Foreground="{StaticResource CodexBarTextBrush}" />
        <TextBlock Text="{Binding CostLast30DaysText}"
                   FontSize="13"
                   Margin="0,4,0,0"
                   Foreground="{StaticResource CodexBarTextBrush}" />
      </StackPanel>

      <Border BorderBrush="#1F000000"
              BorderThickness="0,1,0,0"
              Margin="12,0,12,9" />

      <ItemsControl ItemsSource="{Binding FooterPrimaryRows}"
                    Margin="12,0,12,6">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Button Command="{Binding Command}"
                    Style="{StaticResource MenuActionButton}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding IconGlyph}"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="15"
                           Width="25"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource CodexBarTextBrush}" />
                <TextBlock Text="{Binding Title}"
                           FontSize="17"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource CodexBarTextBrush}" />
              </StackPanel>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <Border BorderBrush="#1F000000"
              BorderThickness="0,1,0,0"
              Margin="12,0,12,6" />

      <ItemsControl ItemsSource="{Binding FooterSecondaryRows}"
                    Margin="12,0,12,0">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Button Command="{Binding Command}"
                    Style="{StaticResource MenuActionButton}">
              <TextBlock Text="{Binding Title}"
                         FontSize="16"
                         Foreground="{StaticResource CodexBarTextBrush}" />
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </StackPanel>
  </Border>
</Window>
