<Window x:Class="CodexBar.WinApp.Views.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to CodexBar"
        Width="520"
        Height="520"
        WindowStartupLocation="Manual">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock Text="Welcome to CodexBar" FontSize="24" FontWeight="Bold" />
      <TextBlock Text="Choose the providers you want to track. You can change this later in Settings."
                 TextWrapping="Wrap"
                 Foreground="#666666"
                 Margin="0,6,0,0" />
    </StackPanel>

    <Grid Grid.Row="1" Margin="0,18,0,18">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="132" />
        <ColumnDefinition Width="104" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="64" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <CheckBox Content="Enable Codex" IsChecked="{Binding CodexEnabled}" Grid.Row="0" Grid.Column="0" Margin="0,8" />
      <TextBlock Text="{Binding CodexAccountStatus}" Grid.Row="0" Grid.Column="1" Margin="0,8" />
      <TextBlock Text="{Binding CodexAccountDetail}" Grid.Row="0" Grid.Column="2" Margin="0,8" Foreground="#666666" TextTrimming="CharacterEllipsis" />
      <Button Content="Help" Tag="Codex" Grid.Row="0" Grid.Column="3" Margin="6,4" Click="ProviderHelp_Click" />

      <CheckBox Content="Enable Claude" IsChecked="{Binding ClaudeEnabled}" Grid.Row="1" Grid.Column="0" Margin="0,8" />
      <TextBlock Text="{Binding ClaudeAccountStatus}" Grid.Row="1" Grid.Column="1" Margin="0,8" />
      <TextBlock Text="{Binding ClaudeAccountDetail}" Grid.Row="1" Grid.Column="2" Margin="0,8" Foreground="#666666" TextTrimming="CharacterEllipsis" />
      <Button Content="Help" Tag="Claude" Grid.Row="1" Grid.Column="3" Margin="6,4" Click="ProviderHelp_Click" />

      <CheckBox Content="Enable Cursor" IsChecked="{Binding CursorEnabled}" Grid.Row="2" Grid.Column="0" Margin="0,8" />
      <TextBlock Text="{Binding CursorAccountStatus}" Grid.Row="2" Grid.Column="1" Margin="0,8" />
      <TextBlock Text="{Binding CursorAccountDetail}" Grid.Row="2" Grid.Column="2" Margin="0,8" Foreground="#666666" TextTrimming="CharacterEllipsis" />
      <Button Content="Help" Tag="Cursor" Grid.Row="2" Grid.Column="3" Margin="6,4" Click="ProviderHelp_Click" />

      <CheckBox Content="Enable Gemini" IsChecked="{Binding GeminiEnabled}" Grid.Row="3" Grid.Column="0" Margin="0,8" />
      <TextBlock Text="{Binding GeminiAccountStatus}" Grid.Row="3" Grid.Column="1" Margin="0,8" />
      <TextBlock Text="{Binding GeminiAccountDetail}" Grid.Row="3" Grid.Column="2" Margin="0,8" Foreground="#666666" TextTrimming="CharacterEllipsis" />
      <Button Content="Help" Tag="Gemini" Grid.Row="3" Grid.Column="3" Margin="6,4" Click="ProviderHelp_Click" />
    </Grid>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Skip" Width="92" Margin="0,0,8,0" Click="Skip_Click" />
      <Button Content="Get Started" IsDefault="True" Width="112" Click="Save_Click" />
    </StackPanel>
  </Grid>
</Window>
