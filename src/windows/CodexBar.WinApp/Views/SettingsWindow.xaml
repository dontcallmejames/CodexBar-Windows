<Window x:Class="CodexBar.WinApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CodexBar Settings"
        Width="560"
        Height="620">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Text="CodexBar" FontSize="24" FontWeight="Bold" />

    <ScrollViewer Grid.Row="1"
                  Margin="0,18,0,0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel>
        <TextBlock Text="{Binding CurrentVersionText}"
                   FontSize="13"
                   Foreground="#666666"
                   Margin="0,0,0,4" />
        <TextBlock Text="{Binding LatestVersionText}"
                   FontSize="13"
                   Foreground="#666666"
                   Margin="0,0,0,4" />
        <TextBlock Text="{Binding UpdateStatusText}"
                   FontSize="13"
                   Foreground="#666666"
                   Margin="0,0,0,12" />
        <CheckBox Content="Enable Codex" IsChecked="{Binding CodexEnabled}" Margin="0,6" />
        <CheckBox Content="Enable Claude" IsChecked="{Binding ClaudeEnabled}" Margin="0,6" />
        <CheckBox Content="Enable Cursor" IsChecked="{Binding CursorEnabled}" Margin="0,6" />
        <CheckBox Content="Enable Gemini" IsChecked="{Binding GeminiEnabled}" Margin="0,6" />
        <CheckBox Content="Merge tray icon" IsChecked="{Binding MergeTrayIcon}" Margin="0,6" />
        <CheckBox Content="Show usage as used" IsChecked="{Binding ShowUsageAsUsed}" Margin="0,6" />
        <CheckBox Content="Show taskbar dock" IsChecked="{Binding DockOverviewNearTaskbar}" Margin="0,6" />
        <CheckBox Content="Start CodexBar with Windows" IsChecked="{Binding LaunchAtStartup}" Margin="0,6" />

        <TextBlock Text="Accounts" FontSize="17" FontWeight="SemiBold" Margin="0,18,0,6" />
        <Grid Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="78" />
            <ColumnDefinition Width="106" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="56" />
            <ColumnDefinition Width="56" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="Codex" Grid.Row="0" Grid.Column="0" Margin="0,4" FontWeight="SemiBold" />
          <TextBlock Text="{Binding CodexAccountStatus}" Grid.Row="0" Grid.Column="1" Margin="0,4" />
          <TextBlock Text="{Binding CodexAccountDetail}" Grid.Row="0" Grid.Column="2" Margin="0,4" Foreground="#666666" TextTrimming="CharacterEllipsis" />
          <Button Content="Test" Tag="Codex" Grid.Row="0" Grid.Column="3" Margin="4,1" Click="TestProvider_Click" />
          <Button Content="Help" Tag="Codex" Grid.Row="0" Grid.Column="4" Margin="4,1" Click="ProviderHelp_Click" />
          <TextBlock Text="Claude" Grid.Row="1" Grid.Column="0" Margin="0,4" FontWeight="SemiBold" />
          <TextBlock Text="{Binding ClaudeAccountStatus}" Grid.Row="1" Grid.Column="1" Margin="0,4" />
          <TextBlock Text="{Binding ClaudeAccountDetail}" Grid.Row="1" Grid.Column="2" Margin="0,4" Foreground="#666666" TextTrimming="CharacterEllipsis" />
          <Button Content="Test" Tag="Claude" Grid.Row="1" Grid.Column="3" Margin="4,1" Click="TestProvider_Click" />
          <Button Content="Help" Tag="Claude" Grid.Row="1" Grid.Column="4" Margin="4,1" Click="ProviderHelp_Click" />
          <TextBlock Text="Cursor" Grid.Row="2" Grid.Column="0" Margin="0,4" FontWeight="SemiBold" />
          <TextBlock Text="{Binding CursorAccountStatus}" Grid.Row="2" Grid.Column="1" Margin="0,4" />
          <TextBlock Text="{Binding CursorAccountDetail}" Grid.Row="2" Grid.Column="2" Margin="0,4" Foreground="#666666" TextTrimming="CharacterEllipsis" />
          <Button Content="Test" Tag="Cursor" Grid.Row="2" Grid.Column="3" Margin="4,1" Click="TestProvider_Click" />
          <Button Content="Help" Tag="Cursor" Grid.Row="2" Grid.Column="4" Margin="4,1" Click="ProviderHelp_Click" />
          <TextBlock Text="Gemini" Grid.Row="3" Grid.Column="0" Margin="0,4" FontWeight="SemiBold" />
          <TextBlock Text="{Binding GeminiAccountStatus}" Grid.Row="3" Grid.Column="1" Margin="0,4" />
          <TextBlock Text="{Binding GeminiAccountDetail}" Grid.Row="3" Grid.Column="2" Margin="0,4" Foreground="#666666" TextTrimming="CharacterEllipsis" />
          <Button Content="Test" Tag="Gemini" Grid.Row="3" Grid.Column="3" Margin="4,1" Click="TestProvider_Click" />
          <Button Content="Help" Tag="Gemini" Grid.Row="3" Grid.Column="4" Margin="4,1" Click="ProviderHelp_Click" />
        </Grid>

        <TextBlock Text="Claude manual cookie header" Margin="0,12,0,4" />
        <TextBox Text="{Binding ClaudeManualCookieHeader, UpdateSourceTrigger=PropertyChanged}"
                 Height="80"
                 TextWrapping="Wrap"
                 AcceptsReturn="True" />
        <TextBlock Text="Cursor manual cookie header" Margin="0,12,0,4" />
        <TextBox Text="{Binding CursorManualCookieHeader, UpdateSourceTrigger=PropertyChanged}"
                 Height="80"
                 TextWrapping="Wrap"
                 AcceptsReturn="True" />
      </StackPanel>
    </ScrollViewer>

    <Grid Grid.Row="2">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
        <Button Content="Report a Bug..."
                Width="116"
                Margin="0,0,8,0"
                Click="ReportBug_Click" />
        <Button Content="{Binding UpdateActionText}"
                Width="136"
                Click="CheckUpdates_Click" />
      </StackPanel>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Save" IsDefault="True" Width="88" Margin="8,0" Click="Save_Click" />
        <Button Content="Cancel" IsCancel="True" Width="88" Click="Cancel_Click" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
